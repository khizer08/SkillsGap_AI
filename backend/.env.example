MONGO_URI=
DB_NAME=skillgap_ai

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

CHROMA_PERSIST_DIR=./chroma_db

EMAIL_USER=
EMAIL_PASS=
BREVO_API_KEY=

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY_DAYS=7
OTP_EXPIRY_MINUTES=2
OTP_RESEND_LIMIT=3
OTP_RESEND_WINDOW_MINUTES=10

HOST=0.0.0.0
PORT=8000
PRODUCTION=false

# Comma-separated frontend origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cookie settings (set true + none for HTTPS cross-site frontend/backend)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
